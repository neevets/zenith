// Modern Zenith Syntax
let $email = Fuel.Email {}
    |> .subject("My Subject")
    |> .body("How the heck are you?")
    |> .to("guy@example.com", "Some Guy");

try {
    $email.send();
} catch (Fuel.Email.ValidationFailedException $e) {
    println("Validation failed: ", $e);
} catch (Fuel.Email.SendingFailedException $e) {
    println("Driver failed: ", $e);
} finally {
    println("Cleanup regardless of result");
}
