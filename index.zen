// Zenith - Web List Rendering
println("<ul>");

// 1. Quantum Shield SQL: Seguro, limpio y directo.
// 2. Iteración limpia: Sin etiquetas de apertura/cierre constantes.
let $rows = db.query(SELECT * FROM table);

for ($row in $rows) {
    // 3. String Interpolation: Evitamos la concatenación fea de PHP con puntos.
    println("<li>{ $row.field1 } - { $row.field1 }</li>");
}

println("</ul>");