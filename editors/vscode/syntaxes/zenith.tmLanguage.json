{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Zenith",
    "scopeName": "source.zenith",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#variables"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.zenith",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.zenith",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.zenith",
                    "match": "\\b(if|else|while|for|return|match|default|spawn|yield|import|render|middleware|struct|enum)\\b"
                },
                {
                    "name": "storage.type.zenith",
                    "match": "\\b(let|native|fn)\\b"
                },
                {
                    "name": "constant.language.zenith",
                    "match": "\\b(true|false|null)\\b"
                },
                {
                    "name": "support.type.primitive.zenith",
                    "match": "\\b(int|string|bool|any|void|array|map)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.zenith",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.zenith",
                            "match": "\\\\."
                        },
                        {
                            "name": "variable.interpolation.zenith",
                            "begin": "\\{",
                            "end": "\\}",
                            "patterns": [
                                {
                                    "include": "#variables"
                                },
                                {
                                    "include": "#functions"
                                },
                                {
                                    "match": "[a-zA-Z_][a-zA-Z0-9_\\.]*",
                                    "name": "variable.other.readwrite.zenith"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.zenith",
                    "begin": "'",
                    "end": "'"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.dollar.zenith",
                    "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "name": "support.variable.magic.zenith",
                    "match": "\\b(ctx|file|db|json|env)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.pipe.zenith",
                    "match": "\\|>"
                },
                {
                    "name": "keyword.operator.logical.zenith",
                    "match": "&&|\\|\\||!|==|!=|>=|<="
                },
                {
                    "name": "keyword.operator.assignment.zenith",
                    "match": "=|\\+|\\-|\\*|/"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.zenith",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.zenith"
                        }
                    }
                }
            ]
        }
    }
}