{
    "name": "zenith-vscode",
    "displayName": "Zenith Language Support",
    "description": "Syntax highlighting and language configuration for Zenith",
    "version": "0.1.5",
    "license": "MIT",
    "publisher": "neevets",
    "repository": {
        "type": "git",
        "url": "https://github.com/neevets/zenith"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "zenith",
                "aliases": [
                    "Zenith",
                    "zenith"
                ],
                "extensions": [
                    ".zen"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "zenith",
                "scopeName": "source.zenith",
                "path": "./syntaxes/zenith.tmLanguage.json"
            }
        ],
        "iconThemes": [
            {
                "id": "zenith-icons",
                "label": "Zenith Icons",
                "path": "./zenith-icons.json"
            }
        ]
    },
    "icon": "./assets/zen-icon.png",
    "main": "./out/extension.js",
    "activationEvents": [],
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^7.1.4",
        "@types/minimatch": "^3.0.4",
        "@types/mocha": "^9.0.0",
        "@types/node": "14.x",
        "@types/vscode": "^1.60.0",
        "@typescript-eslint/eslint-plugin": "^4.31.1",
        "@typescript-eslint/parser": "^4.31.1",
        "@vscode/test-electron": "^1.6.2",
        "@vscode/vsce": "^3.7.1",
        "eslint": "^7.32.0",
        "glob": "^7.1.7",
        "minimatch": "^3.0.4",
        "mocha": "^9.1.1",
        "node-fetch": "^2.7.0",
        "typescript": "^4.4.3",
        "web-streams-polyfill": "^4.2.0"
    }
}
