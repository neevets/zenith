struct Entry {
    $id: int;
    $data: string;
}

function stress($count: int): int {
    let $m = native.fill($count, null);
    let $i = 0;
    while ($i < $count) {
        $m[$i] = Entry { id: $i, data: "some data" };
        $i = $i + 1;
    }
    return native.count($m);
}

let $start = native.microtime(true);
let $res = stress(2000000);
let $end = native.microtime(true);

println("Zenith Memory Stress(2M) Result: ", $res);
println("Zenith Memory Stress(2M) Time: ", $end - $start, "s");
