function ack($m: int, $n: int): int {
    if ($m == 0) { return $n + 1; }
    if ($n == 0) { return ack($m - 1, 1); }
    return ack($m - 1, ack($m, $n - 1));
}

let $start = native.microtime(true);
let $res = ack(3, 9);
let $end = native.microtime(true);

println("Zenith Ackermann(3, 9) Result: ", $res);
println("Zenith Ackermann(3, 9) Time: ", $end - $start, "s");
