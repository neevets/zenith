function fib($n: int): int {
    if ($n < 2) {
        return $n;
    }
    return fib($n - 1) + fib($n - 2);
}

let $start = native.microtime(true);
let $result = fib(30);
let $end = native.microtime(true);
let $elapsed = $end - $start;

println("Zenith Fibonacci(30) Result: ", $result);
println("Zenith Fibonacci(30) Time: ", $elapsed, " seconds");
